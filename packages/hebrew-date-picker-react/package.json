{
  "name": "hebrew-date-picker-react",
  "version": "0.1.0",
  "description": "Customizable React date picker for Hebrew/Gregorian workflows",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./src/styles.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/styles.css",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm run clean && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "hebrew-calendar",
    "date-picker",
    "react",
    "jewish-calendar",
    "shadcn"
  ],
  "author": "Nachman Libermensh",
  "license": "MIT",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nachman-Libermensh/hebrew-date-utils.git"
  },
  "bugs": {
    "url": "https://github.com/Nachman-Libermensh/hebrew-date-utils/issues"
  },
  "homepage": "https://github.com/Nachman-Libermensh/hebrew-date-utils#readme",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-select": "^2.1.4",
    "clsx": "^2.1.1",
    "hebrew-date-utils": "workspace:*",
    "lucide-react": "^0.469.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "rimraf": "^6.1.3",
    "typescript": "^5.6.3"
  }
}
