{
  "name": "hebrew-date-utils-monorepo",
  "private": true,
  "version": "0.1.5",
  "packageManager": "pnpm@10.6.5",
  "description": "Monorepo for hebrew-date-utils core package and official docs site",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "pnpm --filter hebrew-date-utils build && pnpm --filter @hebrew-date-utils/docs build",
    "build:core": "pnpm --filter hebrew-date-utils build",
    "build:docs": "pnpm --filter @hebrew-date-utils/docs build",
    "dev:docs": "pnpm build:core && pnpm --filter @hebrew-date-utils/docs dev",
    "publish:core": "pnpm --filter hebrew-date-utils publish --access public --no-git-checks",
    "test": "pnpm --filter hebrew-date-utils test",
    "typecheck": "pnpm --filter hebrew-date-utils typecheck && pnpm --filter @hebrew-date-utils/docs typecheck"
  }
}
